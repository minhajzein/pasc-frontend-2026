########################################
# Client (.gitignore) - Next.js app
########################################

# Dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage

# Next.js build output
/.next/
/out/

# Production build
/build

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables (keep secrets out of git)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo

# Vercel / deployment
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

